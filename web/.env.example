# WB26WC — optional cloud sync (Tier B). Leave unset to disable sync entirely;
# the app works fully offline/local without these, and the Supabase client is
# tree-shaken out of the build when they're absent.
#
# These are PUBLIC, build-time values (Vite inlines VITE_* at build). The anon
# key is safe to expose — access is governed by Row-Level Security (see SYNC.md).
# Set them in your Vercel project (Settings → Environment Variables) for the
# `web` root, then redeploy.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
