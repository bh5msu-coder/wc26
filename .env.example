# ── Database ─────────────────────────────────────────────
# Vercel Postgres / Neon / Supabase connection string.
# On Vercel, add a Postgres store and these are injected automatically.
DATABASE_URL="postgresql://user:password@host:5432/wc26?sslmode=require"
# Prisma needs a direct (non-pooled) URL for migrations on serverless Postgres.
DIRECT_URL="postgresql://user:password@host:5432/wc26?sslmode=require"

# ── Auth.js (NextAuth v5) ────────────────────────────────
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"
# Optional GitHub OAuth (leave blank to use email magic-link / credentials only)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ── App ──────────────────────────────────────────────────
# Used for absolute links in emails / OG tags. Set to your Vercel URL in prod.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Seed ─────────────────────────────────────────────────
# Password applied to every seeded account by `npm run db:seed`.
# Leave unset to have the seed generate (and print) a random one.
SEED_PASSWORD=""
