# ── Database ─────────────────────────────────────────────
# Vercel Postgres / Neon / Supabase connection string.
# On Vercel, add a Postgres store and these are injected automatically.
DATABASE_URL="postgresql://user:password@host:5432/wc26?sslmode=require"
# Prisma needs a direct (non-pooled) URL for migrations on serverless Postgres.
DIRECT_URL="postgresql://user:password@host:5432/wc26?sslmode=require"

# ── Auth.js (NextAuth v5) ────────────────────────────────
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"
# Optional GitHub OAuth (leave blank to use email magic-link / credentials only)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ── App ──────────────────────────────────────────────────
# Used for absolute links in emails / OG tags. Set to your Vercel URL in prod.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Results sync (daily Vercel Cron → /api/cron/results) ──
# football-data.org API key. Until this is set, the results sync no-ops.
RESULTS_API_TOKEN=""
# Optional overrides:
RESULTS_API_URL="https://api.football-data.org/v4"
RESULTS_COMPETITION="WC"
# Shared secret Vercel sends as `Authorization: Bearer <CRON_SECRET>` to the cron
# route. Set it so only Vercel Cron can trigger /api/cron/results.
CRON_SECRET=""
